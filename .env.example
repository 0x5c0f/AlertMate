# === AI Copilot ===
# AI_ENABLED:  set to "true" to enable the AI Copilot tab (default: disabled).
# AI_API_KEY:  API key for the AI provider (required when enabled).
# AI_PROVIDER: "gemini" (default) or "custom" for OpenAI-compatible APIs.
#   - Gemini:   get from https://aistudio.google.com/apikey
#   - Custom:   your provider's API key (e.g., OpenAI sk-...)
# AI_BASE_URL: (custom only) base URL, e.g. https://api.openai.com/v1
# AI_MODEL:     model name, e.g. gpt-4o or gemini-3.5-flash
# AI_PROVIDER="gemini"
# AI_API_KEY="..."
# AI_MODEL="gemini-3.5-flash"

# AI_ENABLED="true"    # uncomment to enable

# ALERTMANAGER_URL: Default Alertmanager instance URL for hot-reload.
# Defaults to http://localhost:9093 if not set.
ALERTMANAGER_URL="http://localhost:9093"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
